{
  "name": "artifact-created",
  "description": "Artifact event emitted after write_file creates a file. No astonish-report fence is present, so this artifact renders as a compact ArtifactCard, NOT as an inline EmbeddedFileViewer. Validates the no-marker → card path of the report gate.",
  "category": "downloads",
  "events": [
    { "type": "session", "data": { "sessionId": "sess-artifact-created", "isNew": true } },
    { "type": "text", "data": { "text": "Creating the report..." } },
    { "type": "tool_call", "data": { "name": "write_file", "args": { "path": "/workspace/report.md", "content": "# Report\nFindings..." } } },
    { "type": "tool_result", "data": { "name": "write_file", "result": "File written successfully" } },
    { "type": "artifact", "data": { "path": "/workspace/report.md", "tool_name": "write_file" } },
    { "type": "text", "data": { "text": "I've created the report." } },
    { "type": "done", "data": { "done": true } }
  ]
}
