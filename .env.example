# Astonish Test Environment
# Copy to .env and fill in shared/team values:
#   cp .env.example .env
#
# For per-developer overrides (API keys), create .env.local (also gitignored).
# Precedence: shell env > .env.local > .env
#
# See docs/architecture/testing.md for full details.

# ---------------------------------------------------------------------------
# Integration Tests (make test-integration)
# ---------------------------------------------------------------------------

# Postgres connection string — tests create/drop temporary schemas.
# ASTONISH_TEST_DSN=postgres://postgres:PASSWORD@localhost:5432/astonish_test?sslmode=disable

# ---------------------------------------------------------------------------
# E2E Tests (make test-e2e)
# Requires ASTONISH_TEST_DSN above, plus a provider API key below.
# All E2E tests bootstrap a full platform (fresh DB, real server, real auth).
# Tests needing K8s sandbox also require kubectl + healthy cluster.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Provider API Keys (set the one matching your ASTONISH_E2E_PROVIDER)
# ---------------------------------------------------------------------------

# Bifrost (openai_compat)
# BIFROST_API_KEY=...
# BIFROST_BASE_URL=https://bifrost.local.muxpie.com

# OpenAI
# OPENAI_API_KEY=sk-...

# Google GenAI (Gemini)
# GOOGLE_API_KEY=...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# SAP AI Core
# AICORE_CLIENT_ID=...
# AICORE_CLIENT_SECRET=...
# AICORE_AUTH_URL=...
# AICORE_BASE_URL=...
# AICORE_RESOURCE_GROUP=...

# ---------------------------------------------------------------------------
# MCP Server API Keys (for E2E tests that invoke real MCP tools)
# ---------------------------------------------------------------------------

# Tavily — required for APPS-007b (app MCP data source invocation)
# TAVILY_API_KEY=tvly-...
