# Integration & Smoke Test Environment
# Copy this file to .env.integration and fill in your values:
#   cp .env.integration.example .env.integration
#
# .env.integration is gitignored — it may contain credentials.
# This .example file IS committed as a reference template.

# ---------------------------------------------------------------------------
# Integration Tests (real Postgres)
# ---------------------------------------------------------------------------

# Postgres connection string. Tests create/drop temporary schemas.
# ASTONISH_TEST_DSN=postgres://postgres:PASSWORD@HOST:5432/DB_NAME

# ---------------------------------------------------------------------------
# Cluster Smoke Tests
# ---------------------------------------------------------------------------

# Bearer JWT for API authentication.
# ASTONISH_TEST_TOKEN=eyJ...

# API base URL
# ASTONISH_API_URL=https://your-astonish-instance.example.com

# K8s namespace for sandbox session pods
# ASTONISH_SANDBOX_NS=astonish-sandbox

# Team slug to verify
# ASTONISH_TEST_TEAM=general
