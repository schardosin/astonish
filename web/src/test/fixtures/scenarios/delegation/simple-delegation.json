{
  "name": "simple-delegation",
  "description": "Agent delegates a single task to a sub-agent",
  "category": "delegation",
  "events": [
    { "type": "session", "data": { "sessionId": "sess-delegate-1", "isNew": true } },
    { "type": "text", "data": { "text": "I'll research this for you." } },
    { "type": "subtask_progress", "data": { "event_type": "delegation_start", "tasks": [{ "name": "Research competitors", "description": "Find and analyze top competitors in the market" }] } },
    { "type": "subtask_progress", "data": { "event_type": "task_start", "task_name": "Research competitors" } },
    { "type": "subtask_progress", "data": { "event_type": "task_tool_call", "task_name": "Research competitors", "tool_name": "web_search", "tool_args": { "query": "top competitors SaaS market 2024" } } },
    { "type": "subtask_progress", "data": { "event_type": "task_tool_result", "task_name": "Research competitors", "tool_name": "web_search", "tool_result": "Found 10 results about SaaS competitors..." } },
    { "type": "subtask_progress", "data": { "event_type": "task_text", "task_name": "Research competitors", "text": "I found several key competitors in the SaaS space." } },
    { "type": "subtask_progress", "data": { "event_type": "task_complete", "task_name": "Research competitors", "status": "success", "duration": "3.2s" } },
    { "type": "subtask_progress", "data": { "event_type": "delegation_complete", "status": "success" } },
    { "type": "text", "data": { "text": "Based on my research, here are the top competitors in the market." } },
    { "type": "usage", "data": { "input_tokens": 500, "output_tokens": 250, "total_tokens": 750 } },
    { "type": "done", "data": { "done": true } }
  ]
}
